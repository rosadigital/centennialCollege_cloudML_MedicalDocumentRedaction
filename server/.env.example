# Copy to .env in server/ and adjust. Run uvicorn from server/.

APP_NAME=Medical Records Redaction API
DEBUG=false
# Comma-separated list (not JSON). Same format in Docker backend.env on EC2.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

AWS_REGION=us-east-1

SYNC_MAX_BYTES=512000
SYNC_MAX_SECONDS=60

REDACTION_TOKEN=[REDACTED]
CONFIDENCE_REVIEW_THRESHOLD=0.75

# true = Comprehend Medical + DetectPii (IAM + costs; text sent to AWS)
USE_AWS_COMPREHEND=false
